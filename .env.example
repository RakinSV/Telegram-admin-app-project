# ===== Веб-админка (F23, Фаза 5) =====
# Оставь пустыми — сгенерируются автоматически при первом запуске /setup.
# WEBUI_MASTER_KEY шифрует секреты в БД: ПОТЕРЯ ЭТОГО КЛЮЧА = секреты в БД
# невосстановимы (бэкапь .env вместе с БД!). WEBUI_SESSION_SECRET подписывает
# cookie-сессии — потеря просто разлогинивает всех, не теряет данные.
WEBUI_MASTER_KEY=
WEBUI_SESSION_SECRET=

# ===== Telegram (Telethon, юзер-сессия для чтения каналов) =====
# Можно оставить пустыми и заполнить через веб-админку (http://127.0.0.1:8000/setup) —
# веб-сервер поднимется в любом случае, Telethon/бот стартуют только когда
# все обязательные поля ниже заданы (см. Settings.is_minimally_configured).
# api_id / api_hash получить на https://my.telegram.org
TG_API_ID=
TG_API_HASH=
# Session string генерируется скриптом: python -m tg_repost.tools.gen_session
# (визард генерации session string прямо в браузере — Фаза 5.2)
TG_SESSION_STRING=

# ===== Telegram (Bot API, постинг и модерация) =====
# Токен бота от @BotFather
TG_BOT_TOKEN=
# Твой Telegram user_id (узнать у @userinfobot) — кому бот шлёт посты на модерацию
TG_OWNER_USER_ID=
# Целевые группы публикации настраиваются НЕ здесь, а через CLI после первого
# запуска (бот должен быть админом группы/канала):
#   python -m tg_repost.cli add-target -1001234567890 --title "Мой канал"
# Для каналов/супергрупп chat_id — число со знаком минус.

# ===== Рерайт (OpenAI-совместимое API) =====
# base_url для любого совместимого провайдера:
#   OpenAI:        https://api.openai.com/v1
#   Локально (LM): http://localhost:11434/v1   (Ollama)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ===== БД =====
DATABASE_URL=sqlite:///tg_repost.db

# ===== Фильтрация (F03), опционально, через запятую =====
# Глобальные стоп-слова (пост помечается filtered_out, если встречается слово)
FILTER_STOP_WORDS=
# Глобальные обязательные слова (пост проходит, только если есть хотя бы одно)
FILTER_REQUIRED_WORDS=

# ===== Поведение пайплайна =====
# Интервал тика пайплайна (рерайт/модерация/публикация), сек
PIPELINE_INTERVAL_SECONDS=30
# Авто-постинг без ручной модерации: rewritten постят без кнопок
AUTO_POST_ENABLED=false
# Уровень логирования: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ===== F17: антибан-механики (Telethon юзер-сессия) =====
# Случайная пауза при обработке входящего поста (джиттер), сек
LISTENER_MIN_DELAY_SECONDS=0.5
LISTENER_MAX_DELAY_SECONDS=3.0
# Лимит "тяжёлых" действий чтения (скачивание медиа и т.п.) в час
MAX_READS_PER_HOUR=200

# ===== F11: авто-постинг по расписанию (слоты) =====
# Если true — одобренные посты не публикуются мгновенно, а выходят по слотам
SCHEDULED_POSTING_ENABLED=false
# Слоты публикации в формате HH:MM (24ч), через запятую
POSTING_SLOTS=10:00,14:00,19:00
# Сколько одобренных постов выпускать за один слот
POSTING_BATCH_PER_SLOT=1

# ===== F13: семантический дубль-чек (эмбеддинги) =====
# Включает вызов эмбеддингов на каждый пост (доп. расход токенов!)
SEMANTIC_DEDUP_ENABLED=false
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Порог косинусного сходства для признания дублем (0..1)
SEMANTIC_SIMILARITY_THRESHOLD=0.92
# Окно сравнения с недавними постами, дней
DEDUP_WINDOW_DAYS=3

# ===== F14: статистика просмотров =====
STATS_ENABLED=false
# Период опроса просмотров, минут
STATS_INTERVAL_MINUTES=60
# За какой период считать /stats, дней
STATS_WINDOW_DAYS=7

# ===== F15: стиль-профили рерайта =====
# Профиль по умолчанию (имя файла промпта в rewriter/prompts без .txt).
# Доступны: default, news, opinion, instruction, humor.
# Профиль на конкретный источник: CLI set-source-style @channel news
DEFAULT_STYLE_PROFILE=default

# ===== F16: поиск доп. источников (Brave Search) =====
# Глобальная "галочка добора знаний". Per-source: set-source-enrich @ch on|off
ENABLE_SOURCE_ENRICHMENT=false
# Ключ Brave Search API (есть бесплатный тир): https://brave.com/search/api/
BRAVE_API_KEY=
BRAVE_SEARCH_URL=https://api.search.brave.com/res/v1/web/search
# Сколько результатов запрашивать и сколько максимум вставлять в блок "Источники"
ENRICHMENT_MAX_RESULTS=8
ENRICHMENT_MAX_SOURCES=3

# ===== F18: авто-обложки =====
ENABLE_AUTO_COVER=false
# Стратегия: unsplash (стоковое фото, проще) | comfyui (уникальная AI-генерация)
COVER_STRATEGY=unsplash
# Unsplash: бесплатный ключ на https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=
UNSPLASH_API_URL=https://api.unsplash.com/photos/random
# ComfyUI: локальный сервер + workflow в API-формате (Settings → Enable Dev
# mode → экспорт "Save (API Format)"). Узел промпта зависит от твоего workflow.
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_WORKFLOW_PATH=
COMFYUI_POSITIVE_NODE_ID=
COMFYUI_POLL_ATTEMPTS=60
COMFYUI_POLL_INTERVAL_SECONDS=2

# ===== F19: умное расписание (рекомендация через /best_times, применение —
# кнопкой на /stats/best-times или автоматически раз в сутки) =====
SMART_SCHEDULE_MIN_POSTS=20
SMART_SCHEDULE_TOP_N=3
SMART_SCHEDULE_WINDOW_DAYS=21
SMART_SCHEDULE_AUTO_APPLY=false

# ===== F20: авто-дайджест =====
DIGEST_ENABLED=false
# День недели для cron: mon,tue,wed,thu,fri,sat,sun
DIGEST_DAY_OF_WEEK=sun
DIGEST_HOUR=12
DIGEST_MINUTE=0
DIGEST_TOP_N=5
DIGEST_WINDOW_DAYS=7

# ===== F21: нативная реклама =====
# Каждый N-й опубликованный обычный пост — рекламный. 0 = выключено.
# Брифы добавляются через CLI: add-ad-brief "текст брифа" [--max-uses N]
AD_EVERY_NTH_POST=0

# ===== F22: growth-трекер (каркас — сбор данных + отчёт через /growth) =====
GROWTH_TRACKING_ENABLED=false
GROWTH_SNAPSHOT_INTERVAL_MINUTES=360
GROWTH_MIN_SNAPSHOTS=2
GROWTH_REPORT_WINDOW_DAYS=7
