# ===== Веб-админка (F23, Фаза 5) =====
# Оставь пустыми — сгенерируются автоматически при первом запуске /setup.
# WEBUI_MASTER_KEY шифрует секреты в БД: ПОТЕРЯ ЭТОГО КЛЮЧА = секреты в БД
# невосстановимы (бэкапь .env вместе с БД!). WEBUI_SESSION_SECRET подписывает
# cookie-сессии — потеря просто разлогинивает всех, не теряет данные.
WEBUI_MASTER_KEY=
WEBUI_SESSION_SECRET=
# WEBUI_HOST/WEBUI_PORT — адрес, на котором слушает встроенный веб-сервер.
# Не хранится в БД (см. main.py) — только окружение, т.к. смена требует
# перезапуска процесса. По умолчанию 127.0.0.1:8000 для запуска без Docker.
# В Docker (docker-compose.yml) переопределяется на 0.0.0.0:8000 —
# localhost-only периметр сохраняется публикацией порта самим Docker'ом
# (`-p 127.0.0.1:8000:8000`), а не биндом приложения.
WEBUI_HOST=127.0.0.1
WEBUI_PORT=8000

# ===== Telegram (Telethon, юзер-сессия для чтения каналов) =====
# Можно оставить пустыми и заполнить через веб-админку (http://127.0.0.1:8000/setup) —
# веб-сервер поднимется в любом случае, Telethon/бот стартуют только когда
# все обязательные поля ниже заданы (см. Settings.is_minimally_configured).
# api_id / api_hash получить на https://my.telegram.org
TG_API_ID=
TG_API_HASH=
# Session string генерируется скриптом: python -m tg_repost.tools.gen_session
# (визард генерации session string прямо в браузере — Фаза 5.2)
TG_SESSION_STRING=

# ===== Telegram (Bot API, постинг и модерация) =====
# Токен бота от @BotFather
TG_BOT_TOKEN=
# Твой Telegram user_id (узнать у @userinfobot) — кому бот шлёт посты на модерацию
TG_OWNER_USER_ID=
# Целевые группы публикации настраиваются НЕ здесь, а через CLI после первого
# запуска (бот должен быть админом группы/канала):
#   python -m tg_repost.cli add-target -1001234567890 --title "Мой канал"
# Для каналов/супергрупп chat_id — число со знаком минус.

# ===== Прокси =====
# MTProto-прокси — для Telethon (юзер-сессия говорит с Telegram по MTProto).
# Один общий прокси на основную сессию И все дополнительные из ротации (F26).
# Host/port можно оставить пустыми и заполнить через /settings, secret —
# только через /secrets (write-only).
# ВНИМАНИЕ: секреты с префиксом `ee` (fake-TLS) Telethon НЕ поддерживает
# (репо Telethon заархивирован 02.2026, поддержку так и не добавили) — если
# твой секрет начинается на ee, используй SOCKS5-туннель ниже вместо этого.
MTPROTO_PROXY_HOST=
MTPROTO_PROXY_PORT=
MTPROTO_PROXY_SECRET=
# SOCKS5-туннель для Telethon — АЛЬТЕРНАТИВА MTProto-прокси выше и
# рекомендуемый путь при блокировках: обычный TCP-туннель к серверам
# Telegram, без ограничения fake-TLS. Если задан — имеет ПРИОРИТЕТ над
# MTPROTO_PROXY_*. Формат socks5://[user:pass@]host:port. Через /secrets.
TELETHON_PROXY_URL=
# SOCKS5-прокси для Bot API репост-бота (постинг/модерация) — Bot API ходит
# по HTTPS, MTProto-прокси тут не работает. Логин:пароль опциональны, как и у
# TELETHON_PROXY_URL выше. Формат: socks5://[user:pass@]host:port.
# Тоже через /secrets, не сюда напрямую.
BOT_API_PROXY_URL=

# ===== Рерайт (OpenAI-совместимое API) =====
# base_url для любого совместимого провайдера:
#   OpenAI:        https://api.openai.com/v1
#   Локально (LM): http://localhost:11434/v1   (Ollama)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Промпты рерайта — правь прямо в /settings (текстовые поля), не здесь.
# Редактируются ВСЕ пять стиль-профилей (F15), дефолты зашиты в config.py /
# лежат в tg_repost/rewriter/prompts/*.txt:
#   REWRITE_PROMPT_TEMPLATE      — базовый (default)
#   REWRITE_PROMPT_NEWS          — новость
#   REWRITE_PROMPT_OPINION       — мнение
#   REWRITE_PROMPT_INSTRUCTION   — инструкция
#   REWRITE_PROMPT_HUMOR         — юмор
# Пустое значение любого из них = откат на одноимённый файл в prompts/.

# Анти-ИИ: приклеивает к КАЖДОМУ промпту рерайта (любого стиля) блок правил
# «не звучи как нейросеть» — рваный ритм фраз, без дежурных связок и
# шаблонных конструкций. Сам текст правил правится в /settings.
REWRITE_HUMANIZE_ENABLED=true
# REWRITE_HUMANIZE_INSTRUCTIONS тут не задаётся, дефолт зашит в config.py.

# Насколько свободно модель формулирует. Ниже 0.7 текст сушится и становится
# шаблонным, выше 1.0 растёт риск искажения фактов.
REWRITE_TEMPERATURE=0.8

# Переход по ссылке из поста для "настоящего" рерайта (по полному тексту
# статьи, а не короткому тизеру) — см. /settings, группа "Рерайт".
FETCH_LINK_CONTENT_ENABLED=true
# Сколько символов статьи уходит в модель. Именно этот лимит решает, увидит
# ли она материал целиком или только начало: если рерайт пересказывает лишь
# первые абзацы — поднимай. Больше символов = дороже токены.
LINK_CONTENT_MAX_CHARS=6000
LINK_FETCH_TIMEOUT_SECONDS=10

# Сколько независимых вариантов текста генерировать на пост — выбор лучшего
# в боте (кнопки ◀▶) или в веб-админке (/moderation/{id}). 1 = как раньше,
# без кнопок переключения. Каждый вариант — отдельный платный вызов LLM.
REWRITE_VARIANT_COUNT=1

# ===== БД =====
DATABASE_URL=sqlite:///tg_repost.db

# ===== Фильтрация (F03), опционально, через запятую =====
# Глобальные стоп-слова (пост помечается filtered_out, если встречается слово)
FILTER_STOP_WORDS=
# Глобальные обязательные слова (пост проходит, только если есть хотя бы одно)
FILTER_REQUIRED_WORDS=

# ===== Поведение пайплайна =====
# Интервал тика пайплайна (рерайт/модерация/публикация), сек
PIPELINE_INTERVAL_SECONDS=30
# Авто-постинг без ручной модерации: rewritten постят без кнопок
AUTO_POST_ENABLED=false
# Уровень логирования: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ===== F17: антибан-механики (Telethon юзер-сессия) =====
# Случайная пауза при обработке входящего поста (джиттер), сек
LISTENER_MIN_DELAY_SECONDS=0.5
LISTENER_MAX_DELAY_SECONDS=3.0
# Лимит "тяжёлых" действий чтения (скачивание медиа и т.п.) в час
MAX_READS_PER_HOUR=200
# F26: ротация нескольких Telethon-сессий (снижает риск ограничений при
# большом числе источников на одном аккаунте) — БЕЗ отдельных env-переменных,
# дополнительные сессии хранятся зашифрованными в БД. Управление:
# `python -m tg_repost.cli add-telethon-session <метка>` (session string
# запросится интерактивно, не аргументом — уже сгенерированная через
# tools.gen_session), либо
# страница /telethon-sessions в веб-админке. MAX_READS_PER_HOUR выше — свой
# лимит на КАЖДЫЙ аккаунт, не общий на всех.

# ===== F11: авто-постинг по расписанию (слоты) =====
# Если true — одобренные посты не публикуются мгновенно, а выходят по слотам
SCHEDULED_POSTING_ENABLED=false
# Слоты публикации в формате HH:MM (24ч), через запятую
POSTING_SLOTS=10:00,14:00,19:00
# Сколько одобренных постов выпускать за один слот
POSTING_BATCH_PER_SLOT=1

# ===== F13: семантический дубль-чек (эмбеддинги) =====
# Включает вызов эмбеддингов на каждый пост (доп. расход токенов!)
SEMANTIC_DEDUP_ENABLED=false
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Порог косинусного сходства для признания дублем (0..1)
SEMANTIC_SIMILARITY_THRESHOLD=0.92
# Окно сравнения с недавними постами, дней
DEDUP_WINDOW_DAYS=3

# ===== F14: статистика просмотров =====
STATS_ENABLED=false
# Период опроса просмотров, минут
STATS_INTERVAL_MINUTES=60
# За какой период считать /stats, дней
STATS_WINDOW_DAYS=7

# ===== F25: авто-реакция на негативные реакции =====
# Порог числа негативных реакций (👎💩🤮😡🤬😢😭) для уведомления владельца.
# 0 = выключено.
NEGATIVE_REACTION_THRESHOLD=0
# Если включено — при превышении порога пост ещё и автоматически удаляется.
AUTO_DELETE_ON_NEGATIVE=false
# Потолок авто-удалений в час — защита от скоординированного всплеска
# негативных реакций (бригадинг): при достижении лимита пост всё равно
# уведомляется владельцу, просто НЕ удаляется автоматически.
MAX_AUTO_DELETES_PER_HOUR=5

# ===== F15: стиль-профили рерайта =====
# Профиль по умолчанию (имя файла промпта в rewriter/prompts без .txt).
# Доступны: default, news, opinion, instruction, humor.
# Профиль на конкретный источник: CLI set-source-style @channel news
DEFAULT_STYLE_PROFILE=default

# ===== F16: поиск доп. источников (Brave Search) =====
# Глобальная "галочка добора знаний". Per-source: set-source-enrich @ch on|off
ENABLE_SOURCE_ENRICHMENT=false
# Ключ Brave Search API (есть бесплатный тир): https://brave.com/search/api/
BRAVE_API_KEY=
BRAVE_SEARCH_URL=https://api.search.brave.com/res/v1/web/search
# Сколько результатов запрашивать и сколько максимум вставлять в блок "Источники"
ENRICHMENT_MAX_RESULTS=8
ENRICHMENT_MAX_SOURCES=3

# ===== F24: сравнение версий источников (доп. LLM-вызов, поэтому опционально) =====
# Если ru- и en-источники расходятся в трактовке — добавляет пометку в пост.
VERSION_COMPARISON_ENABLED=false

# ===== F18: авто-обложки =====
ENABLE_AUTO_COVER=false
# Стратегия: unsplash (стоковое фото, проще) | comfyui (уникальная AI-генерация,
# твой сервер) | openai (генерация через уже настроенный выше OpenAI-
# совместимый провайдер рерайта — свой ключ не нужен, см. OPENAI_* выше)
COVER_STRATEGY=unsplash
# Модель и промпт для стратегии openai — модель картиночная, не чат-модель
# рерайта (OPENAI_MODEL выше — другая настройка). Промпт правь через
# /settings (текстовое поле), дефолт зашит в config.py.
COVER_OPENAI_MODEL=black-forest-labs/flux.2-klein-4b
# 1792x1024 — широкая, как Telegram и показывает обложку поста. Квадрат
# 1024x1024 обрезается по краям, из кадра уезжает композиционно важное.
# Провайдер может поддерживать не все размеры.
COVER_OPENAI_IMAGE_SIZE=1792x1024
# Промпты обложек правятся через /settings, не здесь — дефолты в config.py:
#   COVER_IMAGE_PROMPT_TEMPLATE  — уходит прямо в генератор (openai-стратегия)
#   COVER_SEARCH_PROMPT_TEMPLATE — для текстовой модели, подбирающей короткий
#                                  запрос к Unsplash/ComfyUI
# Оба дефолта требуют картинку БЕЗ текста и надписей и ассоциативную сцену
# по теме, а не буквальную иллюстрацию заголовка.
# Сколько независимых вариантов обложки генерировать на пост — отдельно от
# REWRITE_VARIANT_COUNT выше (можно, например, 3 текста и 1 обложку).
# 1 = как раньше, без кнопок переключения.
COVER_VARIANT_COUNT=1
# Unsplash: бесплатный ключ на https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=
UNSPLASH_API_URL=https://api.unsplash.com/photos/random
# ComfyUI: локальный сервер + workflow в API-формате (Settings → Enable Dev
# mode → экспорт "Save (API Format)"). Узел промпта зависит от твоего workflow.
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_WORKFLOW_PATH=
COMFYUI_POSITIVE_NODE_ID=
# Узел негативного CLIPTextEncode. Пусто — негатив из workflow не трогается.
# Заполнить стоит: без явного запрета модели упорно дорисовывают на
# «новостных» картинках надписи и псевдологотипы, а «no text» в позитивном
# промпте одного не хватает. Сам текст негатива правится в /settings.
COMFYUI_NEGATIVE_NODE_ID=
COMFYUI_POLL_ATTEMPTS=60
COMFYUI_POLL_INTERVAL_SECONDS=2

# ===== F19: умное расписание (рекомендация через /best_times, применение —
# кнопкой на /stats/best-times или автоматически раз в сутки) =====
SMART_SCHEDULE_MIN_POSTS=20
SMART_SCHEDULE_TOP_N=3
SMART_SCHEDULE_WINDOW_DAYS=21
SMART_SCHEDULE_AUTO_APPLY=false

# ===== F20: авто-дайджест =====
DIGEST_ENABLED=false
# День недели для cron: mon,tue,wed,thu,fri,sat,sun
DIGEST_DAY_OF_WEEK=sun
DIGEST_HOUR=12
DIGEST_MINUTE=0
DIGEST_TOP_N=5
DIGEST_WINDOW_DAYS=7

# ===== F21: нативная реклама =====
# Каждый N-й опубликованный обычный пост — рекламный. 0 = выключено.
# Брифы добавляются через CLI: add-ad-brief "текст брифа" [--max-uses N]
AD_EVERY_NTH_POST=0

# ===== F22: growth-трекер (каркас — сбор данных + отчёт через /growth) =====
GROWTH_TRACKING_ENABLED=false
GROWTH_SNAPSHOT_INTERVAL_MINUTES=360
GROWTH_MIN_SNAPSHOTS=2
GROWTH_REPORT_WINDOW_DAYS=7

# ===== F34: inline-кнопка "источник" на опубликованном посте =====
POST_SOURCE_BUTTON_ENABLED=false
POST_SOURCE_BUTTON_LABEL=Читать в источнике

# ===== Guardian — бот-модератор группового чата (guardian/), ОТДЕЛЬНЫЙ =====
# ===== процесс/бот от репост-бота выше, см. guardian/GUARDIAN.md          =====
# Токен Guardian-бота от @BotFather (НЕ путать с TG_BOT_TOKEN репост-бота)
GUARDIAN_BOT_TOKEN=
# id группы, которую защищает Guardian (отрицательное число)
GUARDIAN_GROUP_ID=
# id приватного канала для лога модерации (добавить туда бота)
GUARDIAN_LOG_CHANNEL_ID=
# Отдельная БД от репост-бота (своя alembic-цепочка — alembic_guardian.ini)
GUARDIAN_DATABASE_URL=sqlite:///guardian.db
# SOCKS5-прокси для Bot API Guardian (свой, не общий с BOT_API_PROXY_URL
# репост-бота — разные процессы). ТОЛЬКО .env, без веб-формы — Bot()
# строится один раз при старте процесса (как GUARDIAN_BOT_TOKEN выше),
# смена требует перезапуска контейнера guardian, не просто docker compose up.
GUARDIAN_BOT_API_PROXY_URL=

# --- Верификация новых участников (G01) ---
CAPTCHA_TIMEOUT_MINUTES=5     # время на прохождение капчи
CAPTCHA_TYPE=math             # math | button | question

# --- Спам-фильтр (G03/G09/G10) ---
SPAM_MODE=keywords            # keywords | ai | hybrid
AI_SPAM_CONFIDENCE_THRESHOLD=0.8  # ниже — передаём в AI (режим ai|hybrid)

# --- Варны и эскалация (G05) ---
WARN_THRESHOLD_MUTE=2         # варнов до мута
WARN_THRESHOLD_KICK=3         # варнов до кика
WARN_THRESHOLD_BAN=4          # варнов до перм-бана
WARN_TTL_DAYS=30              # через сколько дней сбрасываются варны
MUTE_DURATION_HOURS=1         # длительность мута по умолчанию

# --- Антифлуд (G06) ---
FLOOD_MAX_MESSAGES=5          # сообщений за окно — выше порога варн
FLOOD_WINDOW_SECONDS=10       # окно наблюдения, сек
ALLOW_FORWARDS=true           # false = форварды из других каналов удаляются+варн

# --- Антирейд (G14, Фаза G3) ---
RAID_JOIN_THRESHOLD=5         # участников за период
RAID_JOIN_WINDOW_MINUTES=2    # период наблюдения
RAID_COOLDOWN_MINUTES=10      # тишина после которой снимается рейд-режим

# --- Trusted-пользователи (G12) ---
AUTO_TRUST_AFTER_DAYS=30      # автодоверие через N дней без нарушений (0 = выкл.)
# Юзернейм (без @) или числовой id репост-бота — автоматически идёт в
# trusted при старте Guardian, иначе спам-фильтр будет удалять его посты.
REPOST_BOT_ID=

# --- Анализ профиля нового участника (G15) ---
# Сумма сигналов (нет username +1, новый по id +1, нет фото +1, био с
# ключевыми словами вроде crypto/заработок +2) >= порога -> усиленная
# (math) капча вместо CAPTCHA_TYPE. Не банит сам по себе.
PROFILE_SUSPICION_THRESHOLD=3

# --- Тихие часы / режим строгости (G16) ---
# strict — ссылки вне whitelist удаляются как обычно. soft — только
# логируются, не удаляются (стоп-слова работают в обоих режимах одинаково).
# Переключается вручную (/mode strict|soft) или по расписанию ниже.
STRICT_MODE=true
QUIET_HOURS_ENABLED=false
QUIET_HOURS_START_HOUR=22     # UTC, час начала строгого режима
QUIET_HOURS_END_HOUR=8        # UTC, час окончания строгого режима
